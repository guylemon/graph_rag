{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "entity_name": { "type": "string" },
          "entity_type": {
            "type": "string",
            "enum": [
              "CONCEPT",
              "EVENT",
              "LIFEFORM",
              "LOCATION",
              "ORGANIZATION",
              "PERSON",
              "PRODUCT",
              "TECHNOLOGY"
            ]
          },
          "entity_description": { "type": "string" }
        },
        "required": ["entity_name", "entity_type", "entity_description"]
      }
    }
  },
  "required": ["entities", "relationships"]
}
